import { Router, Response, Request } from "express";
import { requireAuth, AuthRequest } from "../middleware/auth";
import prisma from "../lib/prisma";

const router = Router();

// GET /api/generations
router.get("/", requireAuth, async (req: AuthRequest, res: Response) => {
  try {
    const page = parseInt(req.query.page as string) || 1;
    const limit = parseInt(req.query.limit as string) || 20;
    const skip = (page - 1) * limit;

    const [generations, total] = await Promise.all([
      prisma.generation.findMany({
        where: { userId: req.user!.id },
        orderBy: { createdAt: "desc" },
        skip,
        take: limit,
      }),
      prisma.generation.count({ where: { userId: req.user!.id } }),
    ]);

    res.json({ generations, total, page, pages: Math.ceil(total / limit) });
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

// GET /api/generations/:id
router.get("/:id", requireAuth, async (req: AuthRequest, res: Response) => {
  try {
    const generation = await prisma.generation.findFirst({
      where: { id: req.params.id, userId: req.user!.id },
    });
    if (!generation) return res.status(404).json({ error: "Generation not found" });
    res.json(generation);
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

// DELETE /api/generations/:id
router.delete("/:id", requireAuth, async (req: AuthRequest, res: Response) => {
  try {
    await prisma.generation.deleteMany({
      where: { id: req.params.id, userId: req.user!.id },
    });
    res.json({ success: true });
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

// PATCH /api/generations/:id/share
router.patch("/:id/share", requireAuth, async (req: AuthRequest, res: Response) => {
  try {
    const { isPublic } = req.body;
    const generation = await prisma.generation.findFirst({
      where: { id: req.params.id, userId: req.user!.id },
    });
    if (!generation) return res.status(404).json({ error: "Not found" });

    const updated = await prisma.generation.update({
      where: { id: req.params.id },
      data: { isPublic },
    });
    res.json({ shareToken: updated.shareToken, isPublic: updated.isPublic });
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

// GET /api/generations/share/:token (public)
router.get("/share/:token", async (req: Request, res: Response) => {
  try {
    const generation = await prisma.generation.findFirst({
      where: { shareToken: req.params.token, isPublic: true },
      select: {
        id: true, imageUrl: true, inputUrl: true,
        style: true, roomType: true, prompt: true, createdAt: true,
      },
    });
    if (!generation) return res.status(404).json({ error: "Design not found or not public" });
    res.json(generation);
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

export default router;
