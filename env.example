import { Router, Response } from "express";
import { requireAuth, AuthRequest } from "../middleware/auth";
import prisma from "../lib/prisma";
import crypto from "crypto";

const router = Router();

// GET /api/projects
router.get("/", requireAuth, async (req: AuthRequest, res: Response) => {
  try {
    const projects = await prisma.project.findMany({
      where: { userId: req.user!.id },
      include: {
        generations: {
          orderBy: { createdAt: "desc" },
          take: 1,
          select: { imageUrl: true, createdAt: true },
        },
        _count: { select: { generations: true } },
      },
      orderBy: { createdAt: "desc" },
    });
    res.json(projects);
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

// GET /api/projects/:id
router.get("/:id", requireAuth, async (req: AuthRequest, res: Response) => {
  try {
    const project = await prisma.project.findFirst({
      where: { id: req.params.id, userId: req.user!.id },
      include: {
        generations: { orderBy: { createdAt: "desc" } },
      },
    });
    if (!project) return res.status(404).json({ error: "Project not found" });
    res.json(project);
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

// POST /api/projects
router.post("/", requireAuth, async (req: AuthRequest, res: Response) => {
  try {
    const { name, style, roomType } = req.body;
    const project = await prisma.project.create({
      data: {
        userId: req.user!.id,
        name: name || "Untitled Project",
        style: style || "Modern",
        roomType: roomType || "Living Room",
        shareToken: crypto.randomBytes(16).toString("hex"),
      },
    });
    res.status(201).json(project);
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

// PATCH /api/projects/:id
router.patch("/:id", requireAuth, async (req: AuthRequest, res: Response) => {
  try {
    const { name, style, roomType, isPublic } = req.body;
    const project = await prisma.project.updateMany({
      where: { id: req.params.id, userId: req.user!.id },
      data: { name, style, roomType, isPublic },
    });
    res.json({ success: true });
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

// DELETE /api/projects/:id
router.delete("/:id", requireAuth, async (req: AuthRequest, res: Response) => {
  try {
    await prisma.project.deleteMany({
      where: { id: req.params.id, userId: req.user!.id },
    });
    res.json({ success: true });
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

// GET /api/projects/share/:token (public)
router.get("/share/:token", async (req: Request, res: Response) => {
  try {
    const project = await prisma.project.findFirst({
      where: { shareToken: req.params.token, isPublic: true },
      include: {
        generations: {
          orderBy: { createdAt: "desc" },
          select: { imageUrl: true, inputUrl: true, style: true, roomType: true, prompt: true, createdAt: true },
        },
      },
    });
    if (!project) return res.status(404).json({ error: "Design not found or not public" });
    res.json(project);
  } catch (e: any) {
    res.status(500).json({ error: e.message });
  }
});

export default router;
